{
	"name": "Backend Environment (Python/Django/uv)",
	"dockerComposeFile": "../../docker-compose.yml",

	// Service name from docker-compose.yml that holds Python app
	"service": "web",
	"workspaceFolder": "/workspace/backend",

	// Automate python package installation right after container creation
	"postCreateCommand": "uv sync && uv tool install pre-commit --with pre-commit-uv && /root/.local/bin/pre-commit install --install-hooks",

	// Configure tool-specific properties.
	"customizations": {
		// 1. For VS Code & Cursor users
		"vscode": {
			"extensions": [
				"ms-python.python",
				"charliermarsh.ruff",
				"redhat.vscode-yaml",
				"monosans.djlint",
				"editorconfig.editorconfig"
			],
			"settings": {
				// Force VS Code to display both the root files and the backend folders separately
				"workspace.workspaceFolders": [
					{ "path": "/workspace/backend", "name": "Backend App" },
					{ "path": "/workspace", "name": "Project Root (Configs & Docs)" }
				],
				"python.defaultInterpreterPath": "/workspace/backend/.venv/bin/python",
				"editor.formatOnSave": true,
				"[python]": { "editor.defaultFormatter": "charliermarsh.ruff" },
				"[django-html]": { "editor.defaultFormatter": "monosans.djlint" },
				"prettier.configPath": "/workspace/.prettierignore"
			}
		},

		// 2. For JetBrains (PyCharm) users
		"jetbrains": {
			"backend": "PyCharm",
			"plugins": [
				"com.jetbrains.python",
				"charliermarsh.ruff",
				"EditorConfig"
			]
		}
	}
}
